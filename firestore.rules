rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function: get user role from Firestore
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }

    function isAdminOrStaff() {
      return isAuthenticated() && (getUserRole() == 'admin' || getUserRole() == 'staff');
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ─── USERS ───────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── COMPANIES ───────────────────────────────────────────────
    match /companies/{companyId} {
      allow read: if true;
      allow create: if isAuthenticated() && getUserRole() == 'company';
      allow update: if isAuthenticated() && (
        getUserRole() == 'company' && resource.data.ownerId == request.auth.uid
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── INTERNSHIPS ─────────────────────────────────────────────
    match /internships/{internshipId} {
      allow read: if true;
      allow create: if isAuthenticated() && getUserRole() == 'company';
      allow update: if isAuthenticated() && (
        getUserRole() == 'company' && resource.data.ownerId == request.auth.uid
        || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        getUserRole() == 'company' && resource.data.ownerId == request.auth.uid
        || isAdmin()
      );
    }

    // ─── APPLICATIONS ────────────────────────────────────────────
    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.applicantId
        || isAdmin()
      );
      allow create: if isAuthenticated() && getUserRole() == 'student'
        && request.resource.data.applicantId == request.auth.uid;
      allow update: if isAuthenticated() && (
        getUserRole() == 'company'
        || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── REVIEWS ─────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && getUserRole() == 'student'
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // ─── BOOKMARKS (Company) ────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── INTERNSHIP BOOKMARKS ───────────────────────────────────
    match /internship_bookmarks/{bookmarkId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ─── NOTIFICATIONS ───────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow delete: if isAdmin();
    }

    // ─── CONTACTS ────────────────────────────────────────────────
    match /contacts/{contactId} {
      allow read: if isAdminOrStaff();
      allow create: if true;
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }

    // ─── REPORTS ─────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdminOrStaff();
      allow create: if isAuthenticated()
        && request.resource.data.reporterId == request.auth.uid;
      allow update: if isAdminOrStaff();
      allow delete: if isAdmin();
    }
  }
}
